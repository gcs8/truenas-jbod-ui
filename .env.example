# Host port exposed by Docker Compose.
APP_PORT=8080

# App behavior.
APP_LOG_LEVEL=INFO
APP_DEBUG=false
APP_REFRESH_INTERVAL=30
APP_CACHE_TTL=10
APP_CONFIG_PATH=/app/config/config.yaml

# TrueNAS API connection.
# Base appliance URL only, for example https://truenas.example.local
TRUENAS_HOST=https://truenas.example.local
TRUENAS_API_KEY=
TRUENAS_VERIFY_SSL=false
TRUENAS_TIMEOUT=15
TRUENAS_ENCLOSURE_FILTER=

# Optional SSH enrichment.
SSH_ENABLED=false
SSH_HOST=truenas.example.local
SSH_PORT=22
SSH_USER=jbodmap
SSH_KEY_PATH=/run/ssh/id_truenas
# Optional: only needed if your TrueNAS CORE build supports command-limited sudo
# with a password, but not command-limited nopasswd sudo.
SSH_SUDO_PASSWORD=
SSH_KNOWN_HOSTS_PATH=/run/ssh/known_hosts
SSH_STRICT_HOST_KEY_CHECKING=true
SSH_TIMEOUT=15
# Non-root example that keeps glabel/zpool plain and uses command-limited sudo
# only for SES access:
# SSH_COMMANDS_JSON=["/sbin/glabel status","/usr/local/sbin/zpool status -gP","sudo -n /usr/sbin/sesutil map","sudo -n /usr/sbin/sesutil show"]
# Optional if you also allow SSH identify LED control through command-limited sudo:
# SSH_COMMANDS_JSON=["/sbin/glabel status","/usr/local/sbin/zpool status -gP","sudo -n /usr/sbin/sesutil map","sudo -n /usr/sbin/sesutil show","sudo -n /usr/sbin/sesutil locate -u /dev/ses4 16 on","sudo -n /usr/sbin/sesutil locate -u /dev/ses4 16 off"]
# Optional extra hint source if you also allow command-limited sudo for camcontrol:
# SSH_COMMANDS_JSON=["/sbin/glabel status","/usr/local/sbin/zpool status -gP","sudo -n /usr/sbin/sesutil map","sudo -n /usr/sbin/sesutil show","sudo -n /sbin/camcontrol devlist -v"]

# Layout and persistence.
LAYOUT_SLOT_COUNT=60
LAYOUT_ROWS=4
LAYOUT_COLUMNS=15
LAYOUT_SLOT_NUMBER_BASE=0
LAYOUT_API_SLOT_NUMBER_BASE=1
PATH_MAPPING_FILE=/app/data/slot_mappings.json
PATH_LOG_FILE=/app/logs/app.log
