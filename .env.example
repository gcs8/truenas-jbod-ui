# Host port exposed by Docker Compose.
APP_PORT=8080
# Optional for docker-compose.ghcr.yml. Leave unset to use the latest public GHCR image.
JBOD_UI_IMAGE=

# App behavior.
APP_LOG_LEVEL=INFO
APP_DEBUG=false
APP_REFRESH_INTERVAL=30
APP_CACHE_TTL=10
APP_CONFIG_PATH=/app/config/config.yaml

# TrueNAS API connection.
# Base appliance URL only, for example https://truenas.example.local
TRUENAS_HOST=https://truenas.example.local
# TrueNAS CORE/SCALE use API keys. Quantastor uses API user/password instead.
TRUENAS_API_KEY=
TRUENAS_API_USER=
TRUENAS_API_PASSWORD=
# Appliance family for the single-system env flow. Multi-system configs can set
# platform per system inside config/config.yaml.
TRUENAS_PLATFORM=core
TRUENAS_VERIFY_SSL=true
TRUENAS_TIMEOUT=15
TRUENAS_ENCLOSURE_FILTER=

# Optional SSH enrichment.
SSH_ENABLED=false
SSH_HOST=truenas.example.local
SSH_PORT=22
SSH_USER=jbodmap
SSH_KEY_PATH=/run/ssh/id_truenas
# Optional: use this for password-only appliances when SSH keys are not available.
SSH_PASSWORD=
# Optional: only needed if your TrueNAS CORE build supports command-limited sudo
# with a password, but not command-limited nopasswd sudo.
SSH_SUDO_PASSWORD=
SSH_KNOWN_HOSTS_PATH=/app/data/known_hosts
SSH_STRICT_HOST_KEY_CHECKING=true
SSH_TIMEOUT=15
# Non-root example that keeps glabel/zpool plain and uses command-limited sudo
# only for SES access:
# SSH_COMMANDS_JSON=["/sbin/glabel status","/usr/local/sbin/zpool status -gP","gmultipath list","sudo -n /usr/sbin/sesutil map","sudo -n /usr/sbin/sesutil show"]
# Optional if you also allow SSH identify LED control through command-limited sudo:
# SSH_COMMANDS_JSON=["/sbin/glabel status","/usr/local/sbin/zpool status -gP","gmultipath list","sudo -n /usr/sbin/sesutil map","sudo -n /usr/sbin/sesutil show","sudo -n /usr/sbin/sesutil locate -u /dev/ses4 16 on","sudo -n /usr/sbin/sesutil locate -u /dev/ses4 16 off"]
# Optional extra hint source if you also allow command-limited sudo for camcontrol:
# SSH_COMMANDS_JSON=["/sbin/glabel status","/usr/local/sbin/zpool status -gP","gmultipath list","sudo -n /usr/sbin/sesutil map","sudo -n /usr/sbin/sesutil show","sudo -n /sbin/camcontrol devlist -v"]
# SCALE-friendly example for Linux inventory awareness plus SES reads and LED-state refresh:
# SSH_COMMANDS_JSON=["/usr/sbin/zpool status -gP","/usr/bin/lsblk -o NAME,TYPE,SIZE,MODEL,SERIAL,TRAN,HCTL","/usr/bin/lsscsi -g","sudo -n /usr/bin/sg_ses -p aes /dev/sg27","sudo -n /usr/bin/sg_ses -p aes /dev/sg38","sudo -n /usr/bin/sg_ses -p ec /dev/sg27","sudo -n /usr/bin/sg_ses -p ec /dev/sg38"]
# Generic Linux mdadm/NVMe example:
# SSH_COMMANDS_JSON=["/usr/bin/lsblk -OJ","sudo -n /usr/sbin/mdadm --detail --scan","/usr/sbin/nvme list-subsys -o json"]
# Quantastor is API-first in the current v0.5.x work; SSH/CLI is optional and
# not yet required for the first-pass storage-system inventory view.
# smartctl does not need to be in SSH_COMMANDS_JSON; the app runs it on demand for the selected disk,
# but the SCALE user still needs sudo permission for /usr/sbin/smartctl.

# Layout and persistence.
LAYOUT_SLOT_COUNT=60
LAYOUT_ROWS=4
LAYOUT_COLUMNS=15
LAYOUT_SLOT_NUMBER_BASE=0
LAYOUT_API_SLOT_NUMBER_BASE=1
APP_STARTUP_WARM_CACHE_ENABLED=false
APP_STARTUP_WARM_SMART_ENABLED=false
APP_SMART_BATCH_MAX_CONCURRENCY=12
APP_SMART_PREFETCH_DELAY_MS=120
APP_SMART_PREFETCH_STRATEGY=auto
APP_SMART_PREFETCH_SINGLE_THRESHOLD=128
APP_SMART_PREFETCH_CHUNK_SIZE=24
APP_SMART_PREFETCH_BATCH_CONCURRENCY=2
APP_EXPORT_HISTORY_CONCURRENCY=12
APP_EXPORT_CACHE_TTL_SECONDS=60
APP_EXPORT_CACHE_MAX_ENTRIES=8
PATH_MAPPING_FILE=/app/data/slot_mappings.json
PATH_SLOT_DETAIL_CACHE_FILE=/app/data/slot_detail_cache.json
PATH_LOG_FILE=/app/logs/app.log
# Optional profile file for custom chassis layouts.
PATH_PROFILE_FILE=/app/config/profiles.yaml

# Optional performance timing for development / regression checks.
# Leave disabled in normal operation.
PERF_TIMING_ENABLED=false
PERF_LOG_ALL_REQUESTS=false
PERF_SLOW_REQUEST_MS=1000
PERF_SLOW_STAGE_MS=250

# Optional history sidecar. Start it with:
# docker compose --profile history up -d --build
# The main UI renders timestamps in the viewer's browser-local timezone.
HISTORY_PORT=8081
HISTORY_BACKEND_TIMEOUT=10
HISTORY_BACKUP_DIR=/app/history/backups
HISTORY_BACKUP_RETENTION_COUNT=28
HISTORY_LONG_TERM_BACKUP_DIR=/app/history/backups/long-term
HISTORY_WEEKLY_BACKUP_RETENTION_COUNT=4
HISTORY_MONTHLY_BACKUP_RETENTION_COUNT=3
HISTORY_POLL_INTERVAL_SECONDS=300
HISTORY_FAST_INTERVAL_SECONDS=300
HISTORY_SLOW_INTERVAL_SECONDS=21600
HISTORY_REQUEST_TIMEOUT_SECONDS=20
HISTORY_SMART_BATCH_SIZE=24
HISTORY_STARTUP_GRACE_SECONDS=20
